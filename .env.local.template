# Career Portfolio Intelligence Agent - Local Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# REQUIRED: Google Gemini API
# ============================================
# Get your free API key from: https://ai.google.dev/
# Free tier: 15 requests/minute, 1,500 requests/day
GEMINI_API_KEY=

# ============================================
# REQUIRED: Supabase Configuration
# ============================================
# Create a free Supabase project at: https://supabase.com
# Get these values from: Project Settings > API

# Public URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=

# Service key (keep secret, server-side only)
SUPABASE_SERVICE_KEY=

# ============================================
# OPTIONAL: Application Configuration
# ============================================
# URL where the app is running (defaults to localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (development, production, test)
NODE_ENV=development
