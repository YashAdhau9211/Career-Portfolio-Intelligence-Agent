# ============================================================
# Career Portfolio Intelligence Agent - Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, set these in the Vercel dashboard:
#   Project Settings → Environment Variables
# ============================================================

# Google Gemini API
# Get your API key from: https://ai.google.dev/
# Required: yes
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Get these from your Supabase project: Settings → API
# Required: yes
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# Application Configuration
# Set NEXT_PUBLIC_APP_URL to your Vercel deployment URL in production
# e.g. https://your-app.vercel.app
# Required: no (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime environment
# Note: Vercel automatically sets NODE_ENV=production — do not override it.
# For local development use: development
# For running tests use: test
NODE_ENV=development
